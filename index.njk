{% for post in collections.post | reverse %}

  <article>
    <h2>
      <a href="{{ post.url }}">
        {{ post.data.title }}
      </a>
    </h2>

    <small>{{ post.date.toISOString().slice(0, 10) }}</small>

  </article>

{% endfor %}