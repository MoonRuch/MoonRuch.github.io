---
layout: base.njk
title: Главная
---

<h1>Мои мысли</h1>

<p>Заметки, эксперименты, идеи.</p>

<hr>

{% for post in collections.post | reverse %}

  <article style="margin-bottom: 20px;">
    <h2>
      <a href="{{ post.url }}">
        {{ post.data.title }}
      </a>
    </h2>

    <small>{{ post.date | date: "%Y-%m-%d" }}</small>

    <p>{{ post.templateContent | truncate: 120 }}</p>
  </article>

{% endfor %}